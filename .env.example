# Flask
FLASK_APP=app:create_app
FLASK_DEBUG=1
SECRET_KEY=change-me-to-random-bytes-min-32-chars

# Database
DATABASE_URL=postgresql+psycopg://qms:qms@localhost:5432/qms

# Redis
REDIS_URL=redis://localhost:6379/0

# Locale
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=pl,en

# Auth
BCRYPT_LOG_ROUNDS=12
SESSION_LIFETIME_HOURS=8
LOCKOUT_THRESHOLD=5
LOCKOUT_MINUTES=15
